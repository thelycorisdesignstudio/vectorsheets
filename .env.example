PORT=8080
MONGODB_URI=mongodb://127.0.0.1:27017/vectorsheets
MONGODB_DB=vectorsheets
CLIENT_ORIGIN=http://127.0.0.1:5173

# Azure AI Foundry / Azure OpenAI model generation.
# Use a rotated key here. Do not commit real secrets.
AZURE_OPENAI_ENDPOINT=https://eatly-ai.services.ai.azure.com/openai/v1
# Optional override if Azure gives you a full Responses URL:
# AZURE_OPENAI_RESPONSES_URL=https://eatly-ai.services.ai.azure.com/openai/v1/responses
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_TOKEN_SCOPE=https://ai.azure.com/.default
# Set key for API-key auth. Use bearer with AZURE_OPENAI_BEARER_TOKEN, or entra for DefaultAzureCredential.
AZURE_OPENAI_AUTH_MODE=key
AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_BEARER_TOKEN=

# Optional non-Azure OpenAI fallback if AI_PROVIDER=openai or Azure vars are omitted.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
